{
  "name": "dating-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "event-processor": "tsx src/event-processor-entry.ts",
    "seed:mocks": "tsx src/scripts/seed-mock-users.ts",
    "typeorm": "typeorm-ts-node-esm",
    "loadtest": "docker compose --profile loadtest run --rm jmeter",
    "loadtest:stack": "docker compose up -d bot prometheus && docker compose --profile loadtest run --rm jmeter"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@types/amqplib": "^0.10.8",
    "amqplib": "^2.0.1",
    "dotenv": "^16.4.5",
    "grammy": "^1.31.3",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "redis": "^5.8.2",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
